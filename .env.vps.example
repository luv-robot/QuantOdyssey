VPS_HOST=45.32.44.245
POSTGRES_PASSWORD=change-me

# Public HTTPS entrypoints. Set matching A records to the VPS IP.
ACME_EMAIL=luweiword@gmail.com
PUBLIC_HOST=quantodyssey.com
N8N_HOST=quantodyssey.com
BASIC_AUTH_USER=quant
N8N_WEBHOOK_SECRET=

# Required before live LLM-backed research.
OPENAI_API_KEY=

# Optional model providers.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Freqtrade defaults.
FREQTRADE_EXCHANGE=binance
FREQTRADE_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,DOGE/USDT,XRP/USDT,ADA/USDT
FREQTRADE_RELATED_PAIRS=ETH/USDT,SOL/USDT,BNB/USDT
FREQTRADE_STRESS_PAIRS=DOGE/USDT,XRP/USDT,ADA/USDT
FREQTRADE_TIMEFRAMES=5m,15m,1h
FREQTRADE_DOWNLOAD_DAYS=1950
FREQTRADE_WALK_FORWARD_RANGES=20210101-20220101,20220101-20230101,20230101-20240101
FREQTRADE_OOS_TIMERANGE=20240101-20260501
FREQTRADE_CONFIG=/app/configs/freqtrade_config.json

# Prefect schedule. 00:30 UTC = 08:30 Asia/Shanghai.
DAILY_MARKET_DATA_CRON=30 0 * * *
MARKET_SIGNAL_MIN_RANK=1

# n8n notification target. Automatic email requires SMTP/Gmail/SendGrid credentials in n8n.
NOTIFICATION_EMAIL=luweiword@gmail.com
